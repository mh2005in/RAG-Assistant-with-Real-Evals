#!/bin/sh
# Secret scanning via gitleaks — blocks commits that stage likely secrets.
# Bypass a false positive with: git commit --no-verify
#
# Enable in a fresh clone with:  git config core.hooksPath .githooks
#
# Install gitleaks (https://github.com/gitleaks/gitleaks#installing):
#   Windows:  winget install gitleaks   |   scoop install gitleaks   |   choco install gitleaks
#   macOS:    brew install gitleaks
#   Linux:    package manager or download from GitHub releases

if ! command -v gitleaks >/dev/null 2>&1; then
    echo "gitleaks is not installed — cannot scan staged changes for secrets." >&2
    echo "Install it:  winget install gitleaks   (or scoop / choco / brew)" >&2
    echo "Docs: https://github.com/gitleaks/gitleaks#installing" >&2
    echo "To commit without scanning (not recommended): git commit --no-verify" >&2
    exit 1
fi

exec gitleaks git --staged --redact --verbose
