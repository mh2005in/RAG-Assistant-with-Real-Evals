# Copy to .env and adjust as needed: `cp .env.example .env`.
# These are local-dev placeholders, not production secrets. Keep the real .env
# out of git (it is .gitignored).

# --- Postgres container (read by docker-compose.yml) ---
POSTGRES_USER=rag
POSTGRES_PASSWORD=rag
POSTGRES_DB=rag
# Host port the database is published on (container still listens on 5432).
POSTGRES_PORT=5435

# --- Host port the app is published on (the app container listens on 8000) ---
APP_PORT=8000

# --- Running the app/tests on the HOST (outside Docker) ---
# Only needed when you run uvicorn/pytest directly on your machine. Must match
# the user/password/db/port above, via the published host port (5435). The app
# CONTAINER does not use this -- docker-compose builds its DATABASE_URL from the
# db service config (host db:5432).
DATABASE_URL=postgresql://rag:rag@localhost:5435/rag

# --- Ollama: local LLM + embedding model (read by docker-compose.yml and app) ---
# Generation model for /answer. gemma2:2b (~1.6GB) is a small ~2B model;
# alternatives include llama3.2:3b and qwen2.5:1.5b.
OLLAMA_MODEL=gemma2:2b
# Embedding model for /process and /retrieve. nomic-embed-text is 768-dim, which
# matches the vector(768) storage column; a different-dimension model would need
# a schema change. After changing either model, re-run
# `docker compose up -d ollama-pull` to fetch it.
OLLAMA_EMBED_MODEL=nomic-embed-text
# CPU vs CUDA for Ollama (the only service doing tensor maths).
#   0   -> CPU, works everywhere (default)
#   all -> use every NVIDIA GPU; needs the NVIDIA Container Toolkit on the host
#   N   -> use N GPUs
# Changing this requires recreating the container: docker compose up -d ollama
OLLAMA_GPU_COUNT=0
# Host port the Ollama API is published on.
OLLAMA_PORT=11434
# Base URL the app uses to reach Ollama (from the host).
OLLAMA_BASE_URL=http://localhost:11434
