# Copy to .env and adjust as needed: `cp .env.example .env`.
# These are local-dev placeholders, not production secrets. Keep the real .env
# out of git (it is .gitignored).

# --- Postgres container (read by docker-compose.yml) ---
POSTGRES_USER=rag
POSTGRES_PASSWORD=rag
POSTGRES_DB=rag
# Host port the database is published on (container still listens on 5432).
POSTGRES_PORT=5435

# --- Application / tests (read by PostgresStorage.connect via $DATABASE_URL) ---
# Must match the user/password/db/port above. Host is localhost when connecting
# from outside the container.
DATABASE_URL=postgresql://rag:rag@localhost:5435/rag

# --- Ollama: local LLM for augmentation (read by docker-compose.yml) ---
# Model to pull and serve. gemma2:2b (~1.6GB) is a small ~2B model; alternatives
# include llama3.2:3b and qwen2.5:1.5b. After changing it, re-run
# `docker compose up -d ollama-pull` to fetch the new model.
OLLAMA_MODEL=gemma2:2b
# Host port the Ollama API is published on.
OLLAMA_PORT=11434
# Base URL the app will use to reach Ollama (from the host, once wired in).
OLLAMA_BASE_URL=http://localhost:11434
